# ==============================================================================
# LMS Platform — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# ==============================================================================


# ------------------------------------------------------------------------------
# Thương hiệu (Brand) — Đổi thông tin của BẠN ở đây
# ------------------------------------------------------------------------------
# Tất cả giá trị này sẽ override file site-config.ts — KHÔNG cần sửa code
NEXT_PUBLIC_SITE_NAME=Tên Academy Của Bạn
NEXT_PUBLIC_SITE_SHORT_NAME=Tên Ngắn
NEXT_PUBLIC_SITE_DOMAIN=yourdomain.com
NEXT_PUBLIC_SITE_TAGLINE=Slogan của bạn
NEXT_PUBLIC_SITE_DESCRIPTION=Mô tả ngắn về platform

# Thông tin chủ sở hữu
NEXT_PUBLIC_OWNER_NAME=Tên Của Bạn
NEXT_PUBLIC_OWNER_BIO=Giới thiệu ngắn
NEXT_PUBLIC_OWNER_AVATAR=/images/about/portrait.jpg

# Màu thương hiệu (CSS hex color)
NEXT_PUBLIC_COLOR_BRAND=#D4A843
NEXT_PUBLIC_COLOR_BRAND_HOVER=#FBBF24
# NEXT_PUBLIC_COLOR_BG=#0a0a0a
# NEXT_PUBLIC_COLOR_SURFACE=#111111
# NEXT_PUBLIC_COLOR_TEXT=#f5f5f5

# Mạng xã hội
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/your-page
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@your-channel
NEXT_PUBLIC_SOCIAL_ZALO=https://zalo.me/your-phone
# NEXT_PUBLIC_SOCIAL_TIKTOK=
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=

# Footer
NEXT_PUBLIC_FOOTER_COPYRIGHT=© 2026 Tên Academy Của Bạn

# License (BẮT BUỘC — điền đúng thông tin của bạn)
# Thông tin này dùng để xác minh bản quyền sử dụng
NEXT_PUBLIC_LICENSE_NAME=Tên Đầy Đủ Của Bạn
NEXT_PUBLIC_LICENSE_EMAIL=email-dang-ky@gmail.com
NEXT_PUBLIC_LICENSE_DATE=2026-05-21

# Bật/tắt tính năng (set "false" để tắt)
# NEXT_PUBLIC_FEATURE_AFFILIATE=true
# NEXT_PUBLIC_FEATURE_COMMUNITY=true
# NEXT_PUBLIC_FEATURE_LEADERBOARD=true
# NEXT_PUBLIC_FEATURE_BLOG=true
# NEXT_PUBLIC_FEATURE_CRM=true
# NEXT_PUBLIC_FEATURE_EMAIL_MARKETING=true


# ------------------------------------------------------------------------------
# Supabase (required)
# ------------------------------------------------------------------------------
# Create a project at https://supabase.com and copy these from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ------------------------------------------------------------------------------
# Application URLs (required)
# ------------------------------------------------------------------------------
# The canonical URL of your deployed site (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com


# ------------------------------------------------------------------------------
# Payment — PayOS (optional, Vietnamese payment gateway)
# ------------------------------------------------------------------------------
# Sign up at https://payos.vn and get credentials from your dashboard
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=


# ------------------------------------------------------------------------------
# Payment — SePay (optional, Vietnamese bank transfer verification)
# ------------------------------------------------------------------------------
# Sign up at https://sepay.vn for automatic bank transfer matching
SEPAY_API_KEY=
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_CODE=


# ------------------------------------------------------------------------------
# Email — AWS SES (required for email features)
# ------------------------------------------------------------------------------
# Create an IAM user with SES permissions in your AWS account
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

# Sender identity (must be verified in SES)
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Your Platform Name


# ------------------------------------------------------------------------------
# Email — Resend (optional, alternative email provider)
# ------------------------------------------------------------------------------
# Sign up at https://resend.com — used for blog notification emails
RESEND_API_KEY=


# ------------------------------------------------------------------------------
# Analytics — Google Analytics (optional)
# ------------------------------------------------------------------------------
# Create a GA4 property at https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager container ID (optional, runs in parallel with GA4).
# Create a container at https://tagmanager.google.com and paste the ID below
# (format: GTM-XXXXXXX). Leave empty to disable — the component renders null.
NEXT_PUBLIC_GTM_ID=""


# ------------------------------------------------------------------------------
# Analytics — Microsoft Clarity (optional)
# ------------------------------------------------------------------------------
# Microsoft Clarity project ID — get free from https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=""


# ------------------------------------------------------------------------------
# SEO — Google Search Console verification (optional)
# ------------------------------------------------------------------------------
# Sign in at https://search.google.com/search-console, add your property, and
# choose the "HTML tag" verification method. Paste ONLY the `content="..."`
# token value below (not the full <meta> tag). Wired into root metadata via
# src/lib/seo-config.ts → metadata.verification.google.
NEXT_PUBLIC_GSC_VERIFICATION=


# ------------------------------------------------------------------------------
# Analytics — Facebook Pixel + Conversions API (optional)
# ------------------------------------------------------------------------------
# Pixel ID GLOBAL (gắn vào root layout, đo toàn site). Có thể override cho từng
# landing page bằng cách tạo cấu hình trong /admin/pixel-settings.
NEXT_PUBLIC_FB_PIXEL_ID=

# Server-side CAPI access token GLOBAL (fallback khi landing không có config DB)
# Lấy từ Events Manager > Settings > Conversions API > Generate access token.
# Mỗi landing page có thể override token riêng qua admin UI.
FB_PIXEL_ID=
FB_CAPI_ACCESS_TOKEN=

# Test event code GLOBAL — chỉ dùng khi đang debug, BỎ TRỐNG khi production.
# Lấy từ Events Manager > Test Events tab.
FB_TEST_EVENT_CODE=


# ------------------------------------------------------------------------------
# Error Monitoring — Sentry (optional)
# ------------------------------------------------------------------------------
# Create a project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# ------------------------------------------------------------------------------
# Bot Protection — Cloudflare Turnstile (optional)
# ------------------------------------------------------------------------------
# Get keys from https://dash.cloudflare.com (Turnstile section)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# ------------------------------------------------------------------------------
# Security — Internal secrets
# ------------------------------------------------------------------------------
# Random strings used for cron job auth and internal webhook verification
# Generate with: openssl rand -hex 32
CRON_SECRET=
INTERNAL_WEBHOOK_SECRET=


# ------------------------------------------------------------------------------
# AI — Anthropic (optional, powers AI chat features)
# ------------------------------------------------------------------------------
# Get an API key from https://console.anthropic.com
ANTHROPIC_API_KEY=


# ------------------------------------------------------------------------------
# Zalo OA — Zalo Official Account integration (optional)
# ------------------------------------------------------------------------------
# Register at https://oa.zalo.me and configure your OA app
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET_KEY=
ZALO_OA_REFRESH_TOKEN=


# ------------------------------------------------------------------------------
# Security — Content Security Policy reporting (optional)
# ------------------------------------------------------------------------------
# URL where the browser sends CSP violation reports.
# You can use a service like https://report-uri.com or your own endpoint.
CSP_REPORT_URI=


# ------------------------------------------------------------------------------
# Rate Limiting — Upstash Redis (optional)
# ------------------------------------------------------------------------------
# Create a Redis database at https://upstash.com
# When not configured, the platform falls back to in-memory rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
