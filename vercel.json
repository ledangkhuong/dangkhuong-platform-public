{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/low-stock-alert",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/aimakemoremoney",
      "schedule": "*/10 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
